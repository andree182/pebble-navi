{
  "author": "jonny",
  "keywords": [
    "pebble-app"
  ],
  "name": "navi-app",
  "pebble": {
    "capabilities": [
      "location",
      "configurable"
    ],
    "displayName": "Navi App",
    "enableMultiJS": true,
    "messageKeys": [
      "REQUEST_WEATHER",
      "IMAGE_CHUNK_INDEX",
      "IMAGE_CHUNKS_TOTAL",
      "IMAGE_CHUNK_DATA",
      "ZOOM_DIR",
      "REQUEST_DESTINATIONS",
      "SELECTED_DEST_INDEX",
      "SAVE_CURRENT_LOCATION",
      "DEST_NAME",
      "DEST_NAMES_TOTAL",
      "STOP_ROUTING",
      "NAV_INFO_LINE1",
      "NAV_INFO_LINE2",
      "ROUTE_ACTIVE",
      "ROUTE_MODE"
    ],
    "projectType": "native",
    "resources": {
      "media": [
        {
          "file": "images/appicon.png",
          "menuIcon": true,
          "name": "IMAGE_MENU_ICON",
          "type": "bitmap"
        }
      ]
    },
    "sdkVersion": "3",
    "targetPlatforms": [
      "emery",
      "gabbro",
      "flint"
    ],
    "uuid": "64f06958-8a2e-4709-b672-0c3a859e7914",
    "watchapp": {
      "watchface": false
    }
  },
  "version": "1.0.4",
  "scripts": {
    "tsc": "tsc",
    "build": "tsc; pebble build",
    "start": "npx tsc; pebble build; pebble install --emulator emery",
    "debug-duo": "pkill -x qemu-pebble; sleep 1; pebble wipe; pebble clean; npx tsc; pebble build; pebble install --emulator flint; pebble logs --emulator flint",
    "debug-time-2": "pkill -x qemu-pebble; sleep 1; pebble wipe; pebble clean; npx tsc; pebble build; pebble install --emulator emery; pebble logs --emulator emery",
    "debug-round-2": "pkill -x qemu-pebble; sleep 1; pebble wipe; pebble clean; npx tsc; pebble build; pebble install --emulator gabbro; pebble logs --emulator gabbro",
    "screenshot": "pebble screenshot screenshot.png",
    "push": "npx tsc; pebble build; pebble install --phone",
    "wipe": "pebble wipe",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "rxjs": "^7.8.2",
    "upng-js": "^2.1.0"
  },
  "devDependencies": {
    "@types/pebblekitjs": "^4.0.33",
    "@types/upng-js": "^2.1.0",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
